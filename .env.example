# Octopus Energy API credentials
# Get your API key from: https://octopus.energy/dashboard/developer/
OCTOPUS_API_KEY=sk_live_xxxxxxxxxxxx

# Account number (found on your Octopus dashboard or any bill)
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX

# Import meter (electricity you consume from the grid)
OCTOPUS_IMPORT_MPAN=1234567890123
OCTOPUS_IMPORT_SERIAL=12A3456789

# Export meter (electricity you send back to the grid)
OCTOPUS_EXPORT_MPAN=1234567890123
OCTOPUS_EXPORT_SERIAL=12A3456789

# Solis Cloud API credentials
# Request API access via: https://solis-service.solisinverters.com/
# Or go to SolisCloud -> Account -> Basic Settings -> API Management
SOLIS_API_ID=1234567890
SOLIS_API_SECRET=abcdef1234567890abcdef1234567890
SOLIS_INVERTER_SN=1234567890
# Timezone offset in hours (0 for UK/GMT, 1 for BST - adjust as needed)
SOLIS_TIMEZONE=0

# Economy 7 off-peak hours (UTC, as decimal hours)
# Default: 00:30-07:30 (typical for South East England)
ECONOMY7_NIGHT_START=0.5
ECONOMY7_NIGHT_END=7.5
